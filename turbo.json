{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    "tsconfig.json"
  ],
  "tasks": {
    "typecheck": {
      "cache": true,
      "dependsOn": [
        "^typecheck"
      ]
    },
    "test": {
      "cache": true,
      "dependsOn": [
        "^test"
      ]
    }
  }
}