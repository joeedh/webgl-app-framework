{
  "name": "webgl-app-framework",
  "version": "1.0.0",
  "scripts": {
    "build": "node tools/esbuilder.js",
    "configure-all": "cd sculptcore && node make.mjs configure && node make.mjs configure native",
    "build-all": "cd sculptcore && node make.mjs codegen && node make.mjs build && node make.mjs build native && node make.mjs node && cd .. && node tools/esbuilder.js",
    "watch": "node tools/esbuilder.js --watch",
    "cyclecheck": "node tools/circular-ref-finder/dist/index.js scripts/core/AppState.ts",
    "check:layers": "node tools/check-layers.js",
    "gen:paths": "node tools/gen-datapaths.mjs",
    "typecheck": "node tools/gen-datapaths.mjs && turbo typecheck",
    "test": "turbo test",
    "watch-typecheck": "npx tsgo --watch",
    "electron": "pnpm --filter @webgl-app-framework/electron_app exec electron --enable-logging main.js --backend native",
    "serv": "node tools/serv.js",
    "serv:restart": "node tools/serv-restart.js",
    "serv:test": "node tools/serv.js 5099",
    "test:e2e": "playwright test",
    "eslint": "npx eslint --cache --cache-location .eslintcache",
    "format": "bash node_modules/.bin/prettier --cache --write \"**/*.{ts,tsx,js,jsx,mjs,cjs}\"",
    "format:check": "bash node_modules/.bin/prettier --check \"**/*.{ts,tsx,js,jsx,mjs,cjs}\"",
    "markdown-toc": "bash tools/run_markdown_toc.sh"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@pathtx/prettier": "3.3.0-dev",
    "@playwright/test": "^1.60.0",
    "@swc/jest": "^0.2.39",
    "@types/node": "^25.9.1",
    "@types/react": "^19.1.5",
    "@typescript-eslint/eslint-plugin": "^6.19.1",
    "@typescript/native-preview": "7.0.0-dev.20260406.1",
    "dependency-cruiser": "^17.4.0",
    "esbuild": "^0.19.7",
    "esbuild-wasm": "^0.28.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "jest": "^30.2.0",
    "markdown-toc": "^1.2.0",
    "nstructjs": "workspace:*",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "typescript-language-server": "^5.1.3"
  },
  "type": "module",
  "dependencies": {
    "btoa": ">=1.2.1",
    "turbo": "^2.9.6"
  },
  "packageManager": "pnpm@10.30.3"
}